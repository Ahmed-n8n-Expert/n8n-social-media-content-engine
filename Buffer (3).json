    {
      "parameters": {
        "jsCode": "// 1. جلب البيانات من الكود السابق\nlet caption = $json.caption_text;\nlet imageUrl = $json.news_image;\n\n// 2. دالة التلخيص لتويتر (265 حرف)\nfunction shorten(text, maxLen) {\n  if (text.length <= maxLen) return text;\n  return text.substr(0, text.lastIndexOf(' ', maxLen)) + \"...\";\n}\n\nconst shortCaption = shorten(caption, 265);\n\n// 3. تريكة لتجاوز خطأ الأبعاد (إضافة Timestamp للرابط)\n// ساعات ده بيخلي سيرفر بافر يتعامل مع الصورة كأنها طلب جديد ويحل مشكلة الـ Fetch\nlet optimizedImage = imageUrl;\nif (imageUrl && imageUrl.includes('http')) {\n    optimizedImage = imageUrl + (imageUrl.includes('?') ? '&' : '?') + 'v=' + Date.now();\n}\n\nreturn [{\n  json: {\n    ...$json,\n    caption_text: shortCaption,\n    news_image: optimizedImage // الرابط المعدل\n  }\n}];"
      },
