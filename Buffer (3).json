    {
      "parameters": {
        "jsCode": "// 1. سحب النص اللي الإيجنت كتبه\nconst text = $json.output[0].content[0].text;\n\n// 2. تنظيف أي علامات Markdown لو الإيجنت حطها (زي ```json)\nconst cleanText = text.replace(/```json/g, '').replace(/```/g, '').trim();\n\ntry {\n  // 3. تحويل النص لـ JSON حقيقي نقدر نستخدمه\n  const data = JSON.parse(cleanText);\n\n  // 4. إرجاع البيانات في خانات واضحة\n  return [\n    {\n      json: {\n        selected_link: data.selected_link || \"Link not found\",\n        caption_text: data.caption_text || \"No caption provided\",\n        news_headline: data.news_headline || \"No headline\",\n        news_image: data.news_image || \"\"\n      }\n    }\n  ];\n} catch (e) {\n  // لو الإيجنت بعت نص مش JSON سليم، بنطلع النص الأصلي عشان نعرف المشكلة فين\n  return [\n    {\n      json: {\n        error: \"Failed to parse JSON from AI\",\n        raw_text: text\n      }\n    }\n  ];\n}"
      },
